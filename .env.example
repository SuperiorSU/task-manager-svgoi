# ─── API ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@HOST:5432/postgres?sslmode=require"
# Redis Cloud: use rediss:// (double-s) for TLS
# Format: rediss://USERNAME:PASSWORD@HOST:PORT
REDIS_URL="rediss://default:YOUR_REDIS_PASSWORD@YOUR_HOST.db.redis.io:PORT"
JWT_ACCESS_SECRET="change-this-in-production"
JWT_REFRESH_SECRET="change-this-in-production-too"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── STORAGE (Supabase) ────────────────────────────
# Supabase project URL: https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Service Role key (from Project Settings → API → service_role) — NEVER expose on client
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_STORAGE_BUCKET="svgoi-tasks"
MAX_FILE_SIZE_MB=10

