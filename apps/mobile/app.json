{
  "expo": {
    "name": "SVGOI Tasks",
    "slug": "taskflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "scheme": "svgoitasks",
    "owner": "godigitify",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.godigitify.svgoitasks",
      "infoPlist": {
        "NSCameraUsageDescription": "Upload task completion proof",
        "NSPhotoLibraryUsageDescription": "Attach photos to tasks",
        "NSPhotoLibraryAddUsageDescription": "Save task files to library"
      }
    },
    "android": {
      "package": "com.godigitify.svgoitasks",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#1A1F2E"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "router": {
      "root": "app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/notification-icon.png",
          "color": "#1A1F2E",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8479ac33-e743-4bd9-9627-60678c653241"
      }
    }
  }
}
